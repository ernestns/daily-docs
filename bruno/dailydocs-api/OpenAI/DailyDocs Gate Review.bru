meta {
  name: DailyDocs Gate Review
  type: http
  seq: 1
}

post {
  url: https://api.openai.com/v1/responses
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{OPENAI_API_KEY}}
}

body:json {
  {
    "model": "gpt-5-nano",
    "reasoning": {
      "effort": "low"
    },
    "input": [
      {
        "role": "system",
        "content": "You are the editor of DailyDocs.\n\nDailyDocs recommends one documentation page each day to software engineers.\n\nYour job is to determine how suitable this page is for that purpose.\n\nA DailyDocs score of 100 means this is among the best pages in the documentation set for daily reading.\nA score of 75 means it is worthwhile but not exceptional.\nA score below 40 means it should almost never be shown.\n\nDailyDocs wants one focused page, not an entire documentation set in one page.\nAll-in-one print pages, whole-book pages, pages with hundreds of headings, and pages with tens of thousands of words should usually score below 40 even when the underlying documentation is good.\nA focused chapter or guide can still be suitable when it is several thousand words, as long as it is self-contained and readable in one sitting.\n\nConsider:\n\n* educational value\n* evergreen content\n* standalone readability\n* conceptual depth\n* practical usefulness\n* whether it is self-contained\n* whether it teaches a concept\n* whether it can be read in one sitting\n* whether an experienced engineer would recommend reading it\n\nDo not favor API indexes, release notes, navigation pages, print pages, all-in-one pages, or generated reference material.\n\nReturn only JSON matching the schema."
      },
      {
        "role": "user",
        "content": "{\"breadcrumbs\":[\"Documentation\",\"Effective Go\"],\"canonical_url\":\"https://go.dev/doc/effective_go\",\"code_ratio\":0.27089208119625224,\"description\":\"\",\"first_paragraph\":\"Common problems companies solve with Go\",\"h1\":\"Effective Go\",\"heading_count\":60,\"headings_sample\":[\"Effective Go\",\"Introduction\",\"Examples\",\"Formatting\",\"Commentary\",\"Names\",\"Package names\",\"Getters\",\"Interface names\",\"MixedCaps\",\"Semicolons\",\"Control structures\",\"If\",\"Redeclaration and reassignment\",\"For\",\"Switch\",\"Type switch\",\"Functions\",\"Multiple return values\",\"Named result parameters\",\"Defer\",\"Data\",\"Allocation with new\",\"Constructors and composite literals\",\"Allocation with make\",\"Arrays\",\"Slices\",\"Two-dimensional slices\",\"Maps\",\"Printing\",\"Append\",\"Initialization\",\"Constants\",\"Variables\",\"The init function\",\"Methods\",\"Pointers vs. Values\",\"Interfaces and other types\",\"Interfaces\",\"Conversions\"],\"link_count\":123,\"link_density\":0.00744146651340069,\"paragraph_count\":296,\"title\":\"Effective Go - The Go Programming Language\",\"url\":\"https://go.dev/doc/effective_go\",\"word_count\":16529}"
      }
    ],
    "text": {
      "format": {
        "type": "json_schema",
        "name": "daily_docs_page_gate",
        "strict": true,
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dailydocs_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "0 means definitely reject; 100 means among the best pages in the documentation set for daily reading."
            },
            "page_type": {
              "type": "string",
              "enum": [
                "tutorial",
                "guide",
                "concept",
                "reference_concept",
                "api_reference",
                "index_page",
                "navigation_page",
                "print_page",
                "release_notes",
                "changelog",
                "exercise_or_quiz",
                "playground",
                "product_page",
                "too_thin",
                "mostly_links",
                "other"
              ]
            }
          },
          "required": [
            "dailydocs_score",
            "page_type"
          ]
        }
      }
    }
  }
}
