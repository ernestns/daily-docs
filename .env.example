# Local development only. Copy this file to .env and fill in local values.

# Required for AI page review. If omitted, the pipeline uses the deterministic
# metadata reviewer. Set AI_REVIEW_PROVIDER to openai or zai when configuring
# a non-default provider; otherwise OpenAI is used when present.
AI_REVIEW_PROVIDER=
OPENAI_API_KEY=

# Optional. Defaults to gpt-5-nano when OPENAI_API_KEY is set.
OPENAI_MODEL=gpt-5-nano

# Optional z.ai provider. Defaults to GLM-4.7-Flash when ZAI_API_KEY is set
# and AI_REVIEW_PROVIDER=zai.
ZAI_API_KEY=
ZAI_MODEL=GLM-4.7-Flash
ZAI_ENDPOINT=https://api.z.ai/api/paas/v4/chat/completions

# Optional local defaults.
ADDR=:8080
DB_PATH=data/dailydocs.sqlite
